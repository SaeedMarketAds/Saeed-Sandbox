import os  # تعديل الحرف الكبير هنا ليعمل الكود
import json
from datetime import datetime
from .utils import save_json, load_json

class InferenceEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
        self.knowledge_path = os.path.join(base_dir, 'data', 'knowledge.json')
        self.memory_path = os.path.join(base_dir, 'memory', 'conversation.json')
        
        self.knowledge = load_json(self.knowledge_path)
        self.memory = load_json(self.memory_path)
    
    def answer(self, user_input):
        # تنظيف النص من الفراغات الزائدة في البداية والنهاية لضمان مطابقة أفضل
        cleaned_input = user_input.strip()
        
        try:
            if cleaned_input in self.knowledge:
                response = self.knowledge[cleaned_input]
            else:
                response = "⚠️ عفواً، لا أملك معلومات عن هذا السؤال حالياً."
            
            # تسجيل المحادثة في الذاكرة
            self.memory[cleaned_input] = {
                'response': response,
                'timestamp': datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            }
            
            save_json(self.memory_path, self.memory)
            return response
            
        except Exception as e:
            # رسالة خطأ داخلية (يفضل تسجيلها في Logs في التطبيقات الحقيقية)
            return f"حدث خطأ داخلي: {e}"
    
    def add_knowledge(self, question, answer):
        # تنظيف السؤال قبل تخزينه أيضاً
        self.knowledge[question.strip()] = answer
        return save_json(self.knowledge_path, self.knowledge)
    
    def get_memory(self):
        return self.memory
